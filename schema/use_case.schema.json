{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "system_prompt"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "description": {"type": "string"},
    "system_prompt": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
